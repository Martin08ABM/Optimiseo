  <!-- CLIENT-SIDE SCRIPT: INTERACTVIDAD Y RESPONSIVIDAD -->
  <script>
    // 1. Menú Responsive Móvil
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileNav = document.getElementById('mobile-nav');

    if (mobileMenuBtn && mobileNav) {
      function checkWidth() {
        if (window.innerWidth <= 768) {
          mobileMenuBtn.style.display = 'block';
        } else {
          mobileMenuBtn.style.display = 'none';
          mobileNav.style.display = 'none';
          mobileMenuBtn.textContent = '☰';
        }
      }

      window.addEventListener('resize', checkWidth);
      checkWidth();

      mobileMenuBtn.addEventListener('click', () => {
        if (mobileNav.style.display === 'flex') {
          mobileNav.style.display = 'none';
          mobileMenuBtn.textContent = '☰';
        } else {
          mobileNav.style.display = 'flex';
          mobileNav.style.flexDirection = 'column';
          mobileNav.style.gap = '1.25rem';
          mobileNav.style.padding = '1.25rem';
          mobileMenuBtn.textContent = '✕';
        }
      });

      // Cerrar menú móvil al hacer clic en un enlace
      mobileNav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileNav.style.display = 'none';
          mobileMenuBtn.textContent = '☰';
        });
      });
    }

    // 2. Interacciones del Presentation Deck (Slides)
    const tabContainer = document.getElementById('deck-tabs');
    if (tabContainer) {
      const tabButtons = tabContainer.querySelectorAll('.deck-tab-btn');
      
      tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          // Desactivar botones anteriores
          tabButtons.forEach(b => b.classList.remove('active'));
          // Activar este botón
          btn.classList.add('active');

          // Ocultar slides anteriores
          const targetId = btn.getAttribute('data-slide');
          const targetSlide = document.getElementById(targetId);
          
          if (targetSlide) {
            const allSlides = document.querySelectorAll('.slide-content');
            allSlides.forEach(slide => slide.classList.remove('active'));
            // Mostrar slide actual
            targetSlide.classList.add('active');
          }
        });
      });
    }

    // 3. Simulación de Optimización de SEO ("Antes vs Después")
    const btnSimulate = document.getElementById('btn-simulate-seo');
    const originalScore = document.getElementById('original-score');
    const optimizedScore = document.getElementById('optimized-score');
    const optimizedText = document.getElementById('optimized-text');
    const optimizedCard = document.getElementById('optimized-card');
    
    const statDensity = document.getElementById('stat-density');
    const statSynonyms = document.getElementById('stat-synonyms');
    const statReadability = document.getElementById('stat-readability');

    if (btnSimulate && optimizedScore && optimizedText && optimizedCard) {
      btnSimulate.addEventListener('click', () => {
        btnSimulate.disabled = true;
        btnSimulate.textContent = 'Optimizando con Gemini... 🪄';
        optimizedCard.style.borderColor = 'rgba(255, 255, 255, 0.2)';
        
        let counter = 0;
        let score = 4.2;
        
        // Efecto incremento de Score
        const interval = setInterval(() => {
          score += 0.3;
          if (score >= 9.6) {
            score = 9.6;
            clearInterval(interval);
            
            // Reescritura final
            optimizedText.innerHTML = `Escribir un buen <span class="text-green-highlight">artículo optimizado</span> requiere conocer directrices de <span class="text-green-highlight">posicionamiento natural</span>. Cuando publicas tu <span class="text-green-highlight">contenido web</span>, los buscadores analizan la semántica de esa <span class="text-green-highlight">publicación</span> en tiempo real. Es por eso que debes enfocar tu redacción en <span class="text-green-highlight">integrar sinónimos ricos</span> para mejorar la legibilidad, multiplicando el tráfico orgánico y garantizando una excelente retención de usuarios.`;
            optimizedText.style.color = '#fff';
            optimizedScore.textContent = '9.6';
            optimizedScore.style.color = 'var(--accent-green)';
            optimizedScore.style.background = 'rgba(22, 163, 74, 0.05)';
            optimizedCard.style.borderColor = 'var(--accent-green)';
            optimizedCard.style.boxShadow = '0 0 30px rgba(22, 163, 74, 0.15)';
            
            statDensity.textContent = '1.9% (Natural)';
            statDensity.style.color = 'var(--accent-green)';
            statSynonyms.textContent = '4 recomendados';
            statSynonyms.style.color = 'var(--accent-green)';
            statReadability.textContent = 'Excelente (Escaneable)';
            statReadability.style.color = 'var(--accent-green)';
            
            btnSimulate.textContent = '¡Optimización Completada! ✓';
            btnSimulate.style.backgroundColor = 'var(--accent-green)';
            btnSimulate.style.borderColor = 'var(--border-dark)';
          } else {
            optimizedScore.textContent = score.toFixed(1);
          }
        }, 60);
      });
    }

    // 4. Tour del Dashboard Real
    const dbTourSidebar = document.querySelector('.db-tour-sidebar');
    if (dbTourSidebar) {
      const tourItems = dbTourSidebar.querySelectorAll('.db-tour-nav-item');
      tourItems.forEach(item => {
        item.addEventListener('click', () => {
          tourItems.forEach(i => i.classList.remove('active'));
          item.classList.add('active');

          const panelId = item.getAttribute('data-panel');
          const activePanel = document.getElementById(panelId);
          
          if (activePanel) {
            const allPanels = document.querySelectorAll('.db-tour-panel');
            allPanels.forEach(p => p.classList.remove('active'));
            activePanel.classList.add('active');
          }
        });
      });
    }

    // 5. Acordeón FAQs (Apertura suave sin plugins externos)
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const question = item.querySelector('.faq-question');
      question.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        
        // Cerrar todos los acordeones
        faqItems.forEach(i => {
          i.classList.remove('active');
        });

        // Si el click no era en uno ya activo, abrirlo
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });
  </script>

